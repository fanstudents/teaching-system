yloadMap&quot;:{},&quot;isCut&quot;:false}\" data-lark-record-format=\"docx/text\"></span></section><h1 data-pm-slice=\"0 0 []\" style=\"margin-left: 8px;margin-right: 8px;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 18px;font-weight: bold;\">思考融入工具调用</span></span></h1><section><span data-lark-record-data=\"{&quot;rootId&quot;:&quot;Q927dUoN9ouuKcxTc26chgGknEb&quot;,&quot;text&quot;:{&quot;initialAttributedTexts&quot;:{&quot;text&quot;:{&quot;0&quot;:&quot;思考融入工具调用&quot;},&quot;attribs&quot;:{&quot;0&quot;:&quot;*0+8&quot;}},&quot;apool&quot;:{&quot;numToAttrib&quot;:{&quot;0&quot;:[&quot;author&quot;,&quot;7273692048102965249&quot;]},&quot;nextNum&quot;:1}},&quot;type&quot;:&quot;heading1&quot;,&quot;referenceRecordMap&quot;:{},&quot;extra&quot;:{&quot;channel&quot;:&quot;saas&quot;,&quot;isEqualBlockSelection&quot;:true,&quot;pasteRandomId&quot;:&quot;28d113a3-546c-4853-94e6-6d5a75789c35&quot;,&quot;mention_page_title&quot;:{},&quot;external_mention_url&quot;:{}},&quot;isKeepQuoteContainer&quot;:false,&quot;isFromCode&quot;:false,&quot;selection&quot;:[{&quot;id&quot;:20,&quot;type&quot;:&quot;text&quot;,&quot;selection&quot;:{&quot;start&quot;:0,&quot;end&quot;:8},&quot;recordId&quot;:&quot;HhDjdQCbOoJ7LIxl0xVc8EDDnze&quot;}],&quot;payloadMap&quot;:{},&quot;isCut&quot;:false}\" data-lark-record-format=\"docx/text\"></span></section><ul style=\"list-style-type: disc;\" class=\"list-paddingleft-1\"><li><p style=\"margin-left: 8px;margin-right: 8px;margin-bottom: 24px;\"><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 15px;\">不同于过往版本在思考模式下无法调用工具的局限，DeepSeek-V3.2 是我们推出的首个</span></span><strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 15px;\">将思考融入工具使用</span></span></strong><span leaf=\"\"><span textstyle=\"\" style=\"font-size: 15px;\">的模型，并且同时支持思考模式与非思考模式的工具调用。我们提出了一种大规模 Agent 训练数据合成方法，构造了大量「难解答，易验证」的强化学习任务（1800+ 环境，85,000+ 复杂指令），大幅提高了模型的泛化能力。</span></span></p></li></ul><section style=\"color: rgba(0, 0, 0, 0.9);font-size: 17px;fo